# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# DRY_RUN=true simulates all on-chain calls (safe, no funds touched).
# Set to false ONLY after a funded wallet + RPC are configured and validated.
DRY_RUN=true

# ── Solana ───────────────────────────────────────────────────────────────────
RPC_URL=

# Signing wallet. base58 secret key OR a JSON byte array.
# In DRY_RUN you can leave this blank — an ephemeral keypair is generated.
WALLET_PRIVATE_KEY=

# The holder token you created on pump.fun, and (optional) its PumpSwap pool.
# Its creator fees fund the reward cycle; its holders receive the airdrops.
TOKEN_MINT=
PUMPSWAP_POOL_ID=

# ── On-chain execution (live mode only) ──────────────────────────────────────
SLIPPAGE_PCT=5                    # PumpSwap AMM slippage, percent
CURVE_SLIPPAGE_PCT=5              # bonding-curve buy slippage tolerance, percent
PRIORITY_FEE_MICROLAMPORTS=50000  # compute-unit price for landing txs under load
COMPUTE_UNIT_LIMIT=200000         # compute-unit limit per transaction

# DRY_RUN only: simulate a GRADUATED token (exercises the canonical-pool path).
SIMULATE_GRADUATED=false

# ── Trigger ──────────────────────────────────────────────────────────────────
# A reward cycle runs on this timer and claims WHATEVER creator fees have accrued
# (it skips silently when the vault is empty — no threshold).
POLL_SCHEDULE=*/5 * * * *         # every 5 minutes
# DRY_RUN only: simulated SOL accrued to the vault per tick (so cycles have fees).
DRY_RUN_FEE_PER_POLL=0.4

# ── Reward loop (dual rewards: $CUPSY + $ANSEM) ─────────────────────────────
# TOKEN_MINT (above) is the holder token — its creator fees fund the cycle.
# Each claim buys BOTH reward tokens and airdrops them to holders pro-rata by
# holdings (no cap while REWARD_CAP_PCT=0).
# Split: 40% → buy $CUPSY, 40% → buy $ANSEM, 20% stays in the operating
# wallet for tx fees + per-recipient ATA rent. (The two pcts may not sum > 100.)
CUPSY_MINT=6NwarBvDkXhByqVp2Qkq5i9XbtA2B3Bwe8SWGu9vpump   # $CUPSY (REQUIRED for live)
CUPSY_BUY_PCT=40                 # % of claim -> buy $CUPSY (airdropped to holders)
ANSEM_MINT=9cRCn9rGT8V2imeM2BaKs13yhMEais3ruM3rPvTGpump   # $ANSEM (REQUIRED for live)
ANSEM_BUY_PCT=40                 # % of claim -> buy $ANSEM (airdropped to holders)
REWARD_CAP_PCT=0                 # per-wallet weight cap, % of supply (0 = no cap, pure pro-rata)
MIN_HOLD=100000                  # min holder-token balance to qualify
CLUSTERS=[]                      # JSON array of address-groups treated as one wallet
AIRDROP_BATCH_SIZE=8
# Extra owner addresses excluded from airdrops (pool vaults, etc.), comma-separated.
AIRDROP_EXCLUDE=
TOKEN_SYMBOL=CUPSEM

# ── Storage (MongoDB) ────────────────────────────────────────────────────────
# Local mongod, or a MongoDB Atlas SRV URI (mongodb+srv://user:pass@cluster/...).
MONGODB_URI=
MONGODB_DB=cupsem

# ── Frontend / CORS ──────────────────────────────────────────────────────────
# Comma-separated allowlist of browser origins that may call the API.
# Use "*" to allow any origin (not recommended). Non-browser calls always pass.
CORS_ORIGINS=

# Secret protecting POST /api/run|pause|resume. Blank = open (dev only).
# In production set a long random string; send it as header x-api-key: <key>.
API_KEY=
